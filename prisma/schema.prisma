generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN // Você (Acesso total, tenantId nulo)
  ADMIN       // Dono do estacionamento
  OPERATOR    // Funcionário da guarita
}

enum ProductType {
  PRODUCT
  SERVICE
}

model Tenant {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessName String           @map("business_name") @db.VarChar(100)
  document     String?          @db.VarChar(20) @unique
  isActive     Boolean?         @default(true) @map("is_active")
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  prices       ParkingPrice?
  sessions     ParkingSession[]
  products     ProductService[]
  users        User[]

  @@map("tenants")
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  name         String   @db.VarChar(100)
  email        String   @unique @db.VarChar(150)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         String?  @default("operator") @db.VarChar(20)
  isActive     Boolean? @default(true) @map("is_active")
  tokenVersion Int?     @default(0) @map("token_version")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([email], map: "idx_users_email")
  @@map("users")
}

model ParkingSession {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  licensePlate     String    @map("license_plate") @db.VarChar(10)
  model            String    @db.VarChar(80)
  locale           String    @db.VarChar(80)
  isParked         Boolean   @default(true) @map("is_parked")
  entryTime        DateTime  @default(now()) @map("entry_time") @db.Timestamptz(6)
  exitTime         DateTime? @map("exit_time") @db.Timestamptz(6)
  totalTimeMinutes Int?      @map("total_time_minutes")
  totalPrice       Decimal?  @map("total_price") @db.Decimal(10, 2)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenantId, licensePlate], map: "idx_sessions_tenant_plate")
  @@map("parking_sessions")
}

model ParkingPrice {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String   @unique(map: "unique_tenant_price") @map("tenant_id") @db.Uuid
  quickStopPrice        Decimal  @map("quick_stop_price") @db.Decimal(10, 2)
  untilTimePrice        Decimal  @map("until_time_price") @db.Decimal(10, 2)
  extraHourPrice        Decimal  @map("extra_hour_price") @db.Decimal(10, 2)
  quickStopLimitMinutes Int      @map("quick_stop_limit_minutes")
  parkingHours          Int      @map("parking_hours")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("parking_prices")
}

model ProductService {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String            @map("tenant_id") @db.Uuid
  title       String            @db.VarChar(100)
  description String?
  amount      Int?              @default(0)
  price       Decimal           @db.Decimal(10, 2)
  type        product_type_enum
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenantId], map: "idx_products_tenant")
  @@map("products_services")
}

enum product_type_enum {
  product
  service
}
